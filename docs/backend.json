{
  "entities": {
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "type": "object",
      "description": "Represents a single financial transaction, either an income or an expense.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Transaction."
        },
        "amount": {
          "type": "number",
          "description": "The monetary value of the transaction."
        },
        "type": {
          "type": "string",
          "description": "The type of transaction: 'income' or 'expense'."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the transaction."
        },
        "date": {
          "type": "string",
          "description": "The date and time of the transaction.",
          "format": "date-time"
        },
        "categoryId": {
          "type": "string",
          "description": "Reference to the Category."
        }
      },
      "required": [
        "id",
        "amount",
        "type",
        "description",
        "date",
        "categoryId"
      ]
    },
    "Category": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Category",
      "type": "object",
      "description": "Represents a classification for financial transactions.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Category."
        },
        "name": {
          "type": "string",
          "description": "The name of the category."
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "Establishment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Establishment",
      "type": "object",
      "description": "Represents a physical or virtual location where transactions occur.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Establishment."
        },
        "name": {
          "type": "string",
          "description": "The name of the establishment."
        },
        "type": {
          "type": "string",
          "description": "The type of establishment."
        },
        "createdAt": {
          "type": "string",
          "description": "Registration date.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}/categories/{categoryId}": {
      "schema": {
        "$ref": "#/entities/Category"
      },
      "description": "Stores financial categories defined by a user."
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": {
        "$ref": "#/entities/Transaction"
      },
      "description": "Stores individual financial transactions for a user."
    },
    "/users/{userId}/establishments/{establishmentId}": {
      "schema": {
        "$ref": "#/entities/Establishment"
      },
      "description": "Stores establishments registered by a user."
    }
  }
}